DATABASE_URL="postgresql://neondb_owner:npg_fhFYoa4C2Sjq@ep-steep-credit-apcfovep-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Copy this file to `.env` before running: npm run db:deploy
# With docker-compose: docker compose up -d && npm run db:deploy

NEXT_PUBLIC_APP_URL=http://localhost:3000
# In dev, GitHub sign-in uses the browser’s request origin (port) so oauth cookies match the callback;
# add every dev URL you use (e.g. http://localhost:3001/...) to the GitHub OAuth App callback list.
NEXT_PUBLIC_WS_HOST=ws://localhost:4001
NEXT_PUBLIC_DEV_USER_ID=alice
DEV_USER_ID=alice

REALTIME_INTERNAL_SECRET=dev-secret-change-me
REALTIME_BROADCAST_URL=http://127.0.0.1:4001/broadcast

# Horizontal realtime fan-out (optional). Example: redis://localhost:6379
REDIS_URL=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth App → Authorization callback URL (single URL for both flows):
#   {NEXT_PUBLIC_APP_URL}/api/auth/github/callback
# Legacy /signin/callback redirects to the same path.
# OAuth callback in GitHub App → `{NEXT_PUBLIC_APP_URL}/api/auth/github/callback` (no braces).
# Encrypt OAuth tokens at rest (recommended prod): min 16 chars.
AGENTMESH_OAUTH_SECRET=
#
# Workspace invite emails (optional; without key, API returns acceptUrl for manual sharing)
# https://resend.com/docs — verified sender domain or onboarding@resend.dev in dev
RESEND_API_KEY=
RESEND_FROM=
# Pure JS clone without system git: USE_ISOMORPHIC_GIT=true or GIT_CLONE_FALLBACK_ISOMORPHIC=true
USE_ISOMORPHIC_GIT=false
GIT_CLONE_FALLBACK_ISOMORPHIC=false

# Used by server-side git clone when no per-request token is supplied
GITHUB_TOKEN=
GITLAB_TOKEN=

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ORCHESTRATOR_MODEL=gpt-4o-mini
# Cloud Agent (/workspace/.../chat) tool-calling model (OpenAI Chat Completions).
OPENAI_CLOUD_AGENT_MODEL=gpt-4o-mini
# Soft cap: max user messages per member per workspace per local day (unset = unlimited).
AGENTMESH_CHAT_DAILY_USER_LIMIT=200
# Future paid tier: Stripe (not wired yet; usage is logged in AgentUsageLedger).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Google AI Studio (Gemini): embeddings + Context Discovery LLM when OpenAI is not set.
# GEMINI_API_KEY and GOOGLE_AI_API_KEY are aliases; set one.
GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=
# Must be a model that supports v1beta batchEmbedContents (e.g. gemini-embedding-001).
# If this is also set in your shell (`export GEMINI_EMBEDDING_MODEL=...`), that value wins over this file unless you `unset` it.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Optional; default 1536 to match pgvector column. See Gemini EmbedContent docs.
# GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=1536
GEMINI_ORCHESTRATOR_MODEL=gemini-2.0-flash

# MCP server (`packages/mcp-server`): Cursor stdio integration
AGENTMESH_WORKSPACE_ID=
AGENTMESH_TOKEN=
# Extension: if set in the environment before launching Cursor/VS Code, overrides empty agentmesh.contextToken.
AGENTMESH_API_BASE_URL=http://localhost:3000

# Optional public API protection (unset = open health/catalog)
AGENTMESH_PUBLIC_API_KEY=

# Requests / minute per client IP for /api/public/v1/* (default 120)
AGENTMESH_PUBLIC_RATE_LIMIT_PER_MIN=

# OIDC / SSO (authorize: GET /api/auth/oidc/start → callback /api/auth/oidc/callback)
# Discovery issuer examples: https://accounts.google.com or your IdP tenant URL.
# SSO_ISSUER=https://accounts.google.com
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/api/auth/oidc/callback
# OIDC_SCOPE=openid email profile
# Add offline_access when your IdP supports refresh tokens (e.g. Google).
# OIDC_SCOPE=openid email profile offline_access
# OIDC_ACCESS_TYPE=offline
# OIDC_PROMPT=consent
# OIDC_AUDIENCE=
# OIDC_RESOURCE=
# OIDC_SKIP_JWT_VERIFY=false
# Marketplace admin API (GET/POST /api/admin/agent-listings, PATCH/DELETE …/[slug])
# AGENTMESH_ADMIN_SECRET=

# Legacy aliases also accepted: SSO_CLIENT_ID / SSO_CLIENT_SECRET
