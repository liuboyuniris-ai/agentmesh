# Production image: WebSocket + /broadcast (AgentMesh realtime).
# Build context: repository root. Deploy: fly deploy --config fly.realtime.toml

FROM node:22-bookworm-slim
WORKDIR /app

COPY . .

RUN npm ci
RUN npx prisma generate

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080
CMD ["npm", "run", "start", "-w", "realtime"]
